#!/usr/bin/env bash
# mdocker — mini Docker pédagogique
# Usage:
#   mdocker pull ubuntu
#   mdocker run [-m <mem>] [--cpus=<n>] ubuntu|<rootfs> [cmd...]

set -euo pipefail

IMAGES_DIR="/tmp/mdocker"

usage() {
    echo "Usage:"
    echo "  mdocker pull ubuntu"
    echo "  mdocker run [-m <mem>] [--cpus=<n>] ubuntu|<rootfs> [cmd...]"
    echo ""
    echo "  -m <mem>      Limite mémoire (ex: 100M, 512M, 1G)"
    echo "  --cpus=<n>    Nombre de CPUs (ex: 1, 2, 0.5)"
    exit 1
}

CMD="${1:-}"; shift || true

# ── mdocker pull ───────────────────────────────────────────────────────────────
if [[ "$CMD" == "pull" ]]; then
    IMAGE="${1:-}"
    if [[ "$IMAGE" != "ubuntu" ]]; then
        echo "Unable to pull '$IMAGE': seul 'ubuntu' est supporté par mdocker."
        exit 1
    fi
    DEST="$IMAGES_DIR/ubuntu"
    if [[ -d "$DEST" ]]; then
        echo "[mdocker] Image '$IMAGE' déjà présente dans $DEST"
        exit 0
    fi
    CODENAME=$(. /etc/os-release && echo "$VERSION_CODENAME")
    echo "[mdocker] Pull ubuntu ($CODENAME) → $DEST"
    echo "[mdocker] Lancement de debootstrap (quelques minutes)..."
    sudo mkdir -p "$DEST"
    sudo debootstrap \
        --include=iproute2,iputils-ping,procps,python3 \
        --variant=minbase \
        "$CODENAME" "$DEST" \
        http://archive.ubuntu.com/ubuntu/
    # Pré-configurer apt (sources.list complet avec universe)
    sudo bash -c "cat > '$DEST/etc/apt/sources.list'" <<EOF
deb http://archive.ubuntu.com/ubuntu $CODENAME main restricted universe multiverse
deb http://archive.ubuntu.com/ubuntu $CODENAME-updates main restricted universe multiverse
deb http://security.ubuntu.com/ubuntu $CODENAME-security main restricted universe multiverse
EOF
    echo "[mdocker] Image ubuntu prête dans $DEST"
    exit 0
fi

[[ "$CMD" == "run" ]] || usage

# ── Parsing des options ────────────────────────────────────────────────────────
MEM=""
CPUS=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m*)
            MEM="${1#-m}"
            [[ -z "$MEM" ]] && { MEM="$2"; shift; }
            shift ;;
        --cpus=*)
            CPUS="${1#--cpus=}"
            shift ;;
        --cpus)
            CPUS="$2"; shift 2 ;;
        -*)
            echo "Option inconnue: $1" >&2; usage ;;
        *)
            break ;;
    esac
done

ROOTFS="${1:?Argument <rootfs> manquant}"; shift
CMD=("${@:-/bin/bash}")

# Résoudre un nom d'image en chemin si ce n'est pas un chemin absolu/relatif
if [[ "$ROOTFS" != /* && "$ROOTFS" != ./* && "$ROOTFS" != ~* ]]; then
    if [[ "$ROOTFS" != "ubuntu" ]]; then
        echo "Unable to find image '$ROOTFS' locally."
        echo "Seul 'ubuntu' est disponible. Lancez : mdocker pull ubuntu"
        exit 1
    fi
    ROOTFS="$IMAGES_DIR/$ROOTFS"
fi

[[ -d "$ROOTFS" ]] || { echo "Erreur: '$ROOTFS' introuvable. Lancez : mdocker pull ubuntu" >&2; exit 1; }

# ── Identifiants uniques basés sur le PID ─────────────────────────────────────
PID=$$
BRIDGE="mdocker0"          # Pont réseau (comme docker0) — l'IP hôte y est attachée
VETH_HOST="eth-$PID"       # Port veth côté bridge (ex: eth-12345)
VETH_CONT="ethc-$PID"      # Port veth côté conteneur (renommé eth0 dans le netns)
NETNS="ns-$PID"
CG="/sys/fs/cgroup/mdocker-$PID"
OVL="/tmp/mdocker-$PID"    # Répertoire temporaire pour l'overlay

HOST_IP="10.200.1.1"
CONT_IP="10.200.1.2"
SUBNET="10.200.1.0/24"

HOST_IFACE=$(ip route get 8.8.8.8 2>/dev/null \
    | awk '{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' \
    | head -1)
HOST_IFACE="${HOST_IFACE:-eth0}"

BRIDGE_CREATED=false

# ── Nettoyage à la sortie ──────────────────────────────────────────────────────
cleanup() {
    echo ""
    echo "[mdocker] Nettoyage..."
    sudo umount "$OVL/merged" 2>/dev/null || true
    rm -rf "$OVL" 2>/dev/null || true
    sudo ip link delete "$VETH_HOST" 2>/dev/null || true
    sudo ip netns delete "$NETNS"    2>/dev/null || true
    sudo iptables -D FORWARD -i "$BRIDGE" -j ACCEPT 2>/dev/null || true
    sudo iptables -D FORWARD -o "$BRIDGE" -j ACCEPT 2>/dev/null || true
    sudo iptables -t nat -D POSTROUTING \
        -s "$SUBNET" -o "$HOST_IFACE" -j MASQUERADE 2>/dev/null || true
    if [[ "$BRIDGE_CREATED" == "true" ]]; then
        sudo ip link delete "$BRIDGE" 2>/dev/null || true
    fi
    sudo rm -rf "$CG" 2>/dev/null || true
    echo "[mdocker] Terminé."
}
trap cleanup EXIT

# ── Vérification des conflits de sous-réseau ──────────────────────────────────
# Si une route pour le même sous-réseau existe déjà sur une autre interface,
# les réponses IP pourraient partir sur la mauvaise interface.
CONFLICT=$(ip route show "$SUBNET" 2>/dev/null | grep -v "^$" | head -1 || true)
if [[ -n "$CONFLICT" ]]; then
    echo "[mdocker] ATTENTION : route résiduelle détectée : $CONFLICT"
    echo "[mdocker] Suppression pour éviter le conflit de routage..."
    CONFLICT_DEV=$(echo "$CONFLICT" | awk '{print $3}')
    sudo ip link delete "$CONFLICT_DEV" 2>/dev/null || \
        sudo ip route del "$SUBNET" 2>/dev/null || true
fi

echo "[mdocker] Démarrage du conteneur (PID hôte: $PID)"
echo "[mdocker] rootfs  : $ROOTFS"
echo "[mdocker] commande: ${CMD[*]}"
[[ -n "$MEM"  ]] && echo "[mdocker] mémoire : $MEM"
[[ -n "$CPUS" ]] && echo "[mdocker] CPUs    : $CPUS"

# ── 1. Cgroups ─────────────────────────────────────────────────────────────────
echo "[mdocker] Configuration des cgroups..."

sudo mkdir -p "$CG"
echo "+cpu +memory +pids" | sudo tee /sys/fs/cgroup/cgroup.subtree_control > /dev/null

if [[ -n "$MEM" ]]; then
    echo "$MEM" | sudo tee "$CG/memory.max" > /dev/null
    echo "  memory.max = $MEM"
fi

if [[ -n "$CPUS" ]]; then
    PERIOD=100000
    QUOTA=$(awk "BEGIN{printf \"%d\", $CPUS * $PERIOD}")
    echo "$QUOTA $PERIOD" | sudo tee "$CG/cpu.max" > /dev/null
    echo "  cpu.max    = $QUOTA/$PERIOD (${CPUS} CPU)"
fi

# ── 2. Réseau (bridge, comme Docker) ──────────────────────────────────────────
#
#  [ eth0 (conteneur) ] <--veth--> [ eth-PID → mdocker0 (10.200.1.1) ] --NAT--> Internet
#
echo "[mdocker] Configuration du réseau..."

# Créer le bridge mdocker0 si absent (analogue à docker0)
if ! sudo ip link show "$BRIDGE" > /dev/null 2>&1; then
    sudo ip link add "$BRIDGE" type bridge
    sudo ip addr add "$HOST_IP/24" dev "$BRIDGE"
    sudo ip link set "$BRIDGE" up
    BRIDGE_CREATED=true
    echo "  Pont $BRIDGE créé ($HOST_IP)"
else
    echo "  Pont $BRIDGE existant ($HOST_IP)"
fi

echo "  $VETH_HOST → $BRIDGE  <-->  eth0 ($CONT_IP) dans $NETNS"

# Namespace réseau pour le conteneur
sudo ip netns add "$NETNS"

# Paire veth : attacher un bout au bridge, l'autre au netns
sudo ip link add "$VETH_HOST" type veth peer name "$VETH_CONT"
sudo ip link set "$VETH_HOST" master "$BRIDGE"
sudo ip link set "$VETH_HOST" up
sudo ip link set "$VETH_CONT" netns "$NETNS"

# Configurer l'interface dans le conteneur
sudo ip netns exec "$NETNS" ip link set "$VETH_CONT" name eth0
sudo ip netns exec "$NETNS" ip link set lo   up
sudo ip netns exec "$NETNS" ip link set eth0 up
sudo ip netns exec "$NETNS" ip addr add "$CONT_IP/24" dev eth0
sudo ip netns exec "$NETNS" ip route add default via "$HOST_IP"

# Forwarding + NAT + autoriser le trafic via le bridge
sudo sysctl -qw net.ipv4.ip_forward=1
sudo iptables -I FORWARD -i "$BRIDGE" -j ACCEPT
sudo iptables -I FORWARD -o "$BRIDGE" -j ACCEPT
sudo iptables -t nat -A POSTROUTING -s "$SUBNET" -o "$HOST_IFACE" -j MASQUERADE

# ── Diagnostic de connectivité ─────────────────────────────────────────────────
echo "[mdocker] Test de connectivité..."
if sudo ip netns exec "$NETNS" ping -c 1 -W 2 "$HOST_IP" > /dev/null 2>&1; then
    echo "  ✓ hôte    OK  ($CONT_IP → $HOST_IP)"
else
    echo "  ✗ hôte    ECHEC"
fi
if sudo ip netns exec "$NETNS" ping -c 1 -W 3 8.8.8.8 > /dev/null 2>&1; then
    echo "  ✓ internet OK  (8.8.8.8)"
else
    echo "  ✗ internet ECHEC"
fi

# ── 3. OverlayFS — couche éphémère par-dessus le rootfs ───────────────────────
#
#  lower  = $ROOTFS          (lecture seule — image de base intacte)
#  upper  = $OVL/upper       (modifications du conteneur, effacées à la sortie)
#  work   = $OVL/work        (usage interne overlayfs)
#  merged = $OVL/merged      (vue combinée — c'est ici qu'on chroote)
#
mkdir -p "$OVL/upper" "$OVL/work" "$OVL/merged"
sudo mount -t overlay overlay \
    -o lowerdir="$ROOTFS",upperdir="$OVL/upper",workdir="$OVL/work" \
    "$OVL/merged"

# ── 4. Lancement du conteneur ─────────────────────────────────────────────────
echo "[mdocker] Lancement..."
echo "──────────────────────────────────────────────────────"

CMD_STR=$(printf '%q ' "${CMD[@]}")

sudo bash -c "
  echo \$\$ > '$CG/cgroup.procs'

  exec nsenter --net='/var/run/netns/$NETNS' \
    unshare --fork --pid --mount --uts --ipc --cgroup \
      chroot '$OVL/merged' \
        /bin/sh -c 'mount -t proc proc /proc 2>/dev/null; exec $CMD_STR'
"
